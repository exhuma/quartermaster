{
  "//": "Dogfoods Quartermaster's own resolve_kits enforcement. Points at the canonical, tested hook scripts under webui/src/docs/claude-code/ (single source of truth) rather than duplicating them into .claude/hooks/. The Integrate page documents these for downstream integrators.",
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/webui/src/docs/claude-code/qm-prompt-reminder.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/webui/src/docs/claude-code/qm-edit-reminder.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "mcp__quartermaster__resolve_kits",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/webui/src/docs/claude-code/qm-record-resolve.sh"
          }
        ]
      }
    ]
  }
}
