# Environment variables for the Quartermaster MCP server.
# Copy this file to .env and fill in all required values.
# Never commit .env — it is listed in .gitignore.

# ---------------------------------------------------------------------------
# Required — Keycloak
# ---------------------------------------------------------------------------

# Base URL of your Keycloak instance (no trailing slash).
KEYCLOAK_URL=https://auth.example.com

# Keycloak realm that issues service-account tokens.
KEYCLOAK_REALM=master

# Optional: expected value of the `aud` claim in incoming JWTs.
# Set this when your Keycloak clients are configured with an explicit
# audience mapper.  Leave commented out to skip audience validation.
# KEYCLOAK_AUDIENCE=quartermaster

# Optional: TLS verification for outbound calls to Keycloak (JWKS fetch and
# the optional Copilot token-endpoint check).
#
# If Keycloak is served by a private/internal CA not in the system trust
# store, point this at a PEM CA bundle so verification succeeds:
# TLS_CA_BUNDLE=/etc/ssl/certs/internal-ca.pem
#
# Or, for quick POC/testing ONLY, disable certificate + hostname checks
# entirely. Never set this in production. Takes precedence over TLS_CA_BUNDLE.
# TLS_INSECURE_SKIP_VERIFY=true

# Optional: space-separated list of OAuth scopes advertised in the
# /.well-known/oauth-authorization-server metadata document.
# Limits what scopes VS Code (and other clients) will request; prevents
# Keycloak from rejecting the auth request with "Invalid scopes".
# Defaults to "openid profile email".
# OAUTH_SCOPES=openid profile email

# ---------------------------------------------------------------------------
# Required — OAuth resource metadata (RFC 9728)
# ---------------------------------------------------------------------------

# Public origin (scheme + host[:port] only, no path, no trailing slash) of
# this server, AS REACHED BY THE BROWSER/CLIENT — not the in-container port.
# Used to construct the OAuth well-known metadata URLs and the
# WWW-Authenticate header (so VS Code and other OAuth-aware clients can
# discover Keycloak), AND the web UI's OIDC redirect URI, post-logout URI,
# and API base that the server renders into /config.js at runtime.
#
# Because the web UI redirect URI is derived from this value, it must match
# the address you actually open in the browser. If you reach the server
# through a port-forward or reverse proxy, set this to THAT externally-
# reachable origin, not the internal one. Examples:
#   - port-forward 50007:8000  -> RESOURCE_BASE_URL=http://localhost:50007
#   - reverse proxy on a host  -> RESOURCE_BASE_URL=https://quartermaster.example.com
# The redirect URI then becomes <RESOURCE_BASE_URL>/auth/callback — register
# exactly that in your Keycloak client's Valid Redirect URIs.
#
# Set this to the origin root, NOT a sub-path:
#   CORRECT:   https://quartermaster.example.com
#   INCORRECT: https://quartermaster.example.com/kits
RESOURCE_BASE_URL=https://quartermaster.example.com

# ---------------------------------------------------------------------------
# Optional — kit discovery
# ---------------------------------------------------------------------------

# Path to the kits/ directory where kit subdirectories live.
# The core image ships NO kits — mount your catalog as a volume and point
# KITS_ROOT at it. The Docker image defaults this to /data/kits (the
# container mount point). For a local source checkout it falls back to
# <repo-root>/kits automatically, so you can leave it unset in dev.
# KITS_ROOT=/data/kits

# Path to the JSON file recording registered client User-Agents. Non-browser
# clients must register their User-Agent (POST /api/clients) before calling
# the API or MCP endpoint. The Docker image defaults this to
# /data/client_registry.json; mount /data to persist it across restarts.
# CLIENT_REGISTRY_PATH=/data/client_registry.json

# Path to the JSON file storing hashed per-user WebDAV app tokens (the
# credentials used to mount the kit catalog). Docker default:
# /data/app_tokens.json. Mount /data to persist across restarts.
# APP_TOKENS_PATH=/data/app_tokens.json

# Require TLS for the /dav WebDAV endpoint (HTTP Basic credentials must not
# travel over plain HTTP). Keep true in production; set false ONLY for local
# non-TLS testing.
# DAV_REQUIRE_TLS=true

# ---------------------------------------------------------------------------
# DEV ONLY — local auth bypass (NEVER set either of these in production)
# ---------------------------------------------------------------------------
# Lets the app run locally without Keycloak. Both default off; leaving them
# unset is what keeps the bypass inert. See DEVELOPMENT.md.
#
# Mounts the /auth/dev/* token-minting routes (a plain 404 when unset):
# DEV_AUTH_ENABLED=true
#
# HS256 signing secret for dev tokens. When unset, HS256 tokens are rejected
# outright — that is the safe default, so NEVER commit a value or set it in
# production. Use a long random string locally.
# DEV_SHARED_SECRET=change-me-to-a-long-random-local-only-string

# ---------------------------------------------------------------------------
# Optional — fixed Copilot header authentication
# ---------------------------------------------------------------------------

# Enable fixed-header auth for clients that send X-Client-Id and
# X-Client-Secret instead of Authorization: Bearer <token>.
# Header values are validated against the Keycloak token endpoint
# using the client_credentials grant.
# This supplements JWT bearer auth; it does not replace it.
# COPILOT_AUTH_ENABLED=false

# Timeout in seconds for token-endpoint validation requests.
# COPILOT_AUTH_TIMEOUT_SECONDS=3.0

# ---------------------------------------------------------------------------
# Optional — GitHub issue materialization for kit requests
# ---------------------------------------------------------------------------

# GitHub repository owner where request_clarification_or_addition will
# create issues.
# GITHUB_OWNER=<your-github-owner>

# GitHub repository name where request_clarification_or_addition will
# create issues.
# GITHUB_REPO=<your-github-repo>

# GitHub token with permission to create issues in GITHUB_OWNER/GITHUB_REPO.
# GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# Optional default assignee GitHub username applied to created issues.
# GITHUB_DEFAULT_ASSIGNEE=octocat
