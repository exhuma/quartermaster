# Environment variables for the Quartermaster MCP server.
# Copy this file to .env and fill in all required values.
# Never commit .env — it is listed in .gitignore.

# ---------------------------------------------------------------------------
# Required — Keycloak
# ---------------------------------------------------------------------------

# Base URL of your Keycloak instance (no trailing slash).
QM_KEYCLOAK_URL=https://auth.example.com

# Keycloak realm that issues service-account tokens.
QM_KEYCLOAK_REALM=master

# Optional: expected value of the `aud` claim in incoming JWTs.
# Set this when your Keycloak clients are configured with an explicit
# audience mapper.  Leave commented out to skip audience validation.
# QM_KEYCLOAK_AUDIENCE=quartermaster

# Optional: TLS verification for outbound calls to Keycloak (JWKS fetch and
# the optional Copilot token-endpoint check).
#
# If Keycloak is served by a private/internal CA not in the system trust
# store, point this at a PEM CA bundle so verification succeeds:
# QM_TLS_CA_BUNDLE=/etc/ssl/certs/internal-ca.pem
#
# Or, for quick POC/testing ONLY, disable certificate + hostname checks
# entirely. Never set this in production. Takes precedence over QM_TLS_CA_BUNDLE.
# QM_TLS_INSECURE_SKIP_VERIFY=true

# Optional: space-separated list of OAuth scopes advertised in the
# /.well-known/oauth-authorization-server metadata document.
# Limits what scopes VS Code (and other clients) will request; prevents
# Keycloak from rejecting the auth request with "Invalid scopes".
# Defaults to "openid profile email".
# QM_OAUTH_SCOPES=openid profile email

# ---------------------------------------------------------------------------
# Required — OAuth resource metadata (RFC 9728)
# ---------------------------------------------------------------------------

# Public origin (scheme + host[:port] only, no path, no trailing slash) of
# this server, AS REACHED BY THE BROWSER/CLIENT — not the in-container port.
# Used to construct the OAuth well-known metadata URLs and the
# WWW-Authenticate header (so VS Code and other OAuth-aware clients can
# discover Keycloak), AND the web UI's OIDC redirect URI, post-logout URI,
# and API base that the server renders into /config.js at runtime.
#
# Because the web UI redirect URI is derived from this value, it must match
# the address you actually open in the browser. If you reach the server
# through a port-forward or reverse proxy, set this to THAT externally-
# reachable origin, not the internal one. Examples:
#   - port-forward 50007:8000  -> QM_RESOURCE_BASE_URL=http://localhost:50007
#   - reverse proxy on a host  -> QM_RESOURCE_BASE_URL=https://quartermaster.example.com
# The redirect URI then becomes <QM_RESOURCE_BASE_URL>/auth/callback — register
# exactly that in your Keycloak client's Valid Redirect URIs.
#
# Set this to the origin root, NOT a sub-path:
#   CORRECT:   https://quartermaster.example.com
#   INCORRECT: https://quartermaster.example.com/kits
QM_RESOURCE_BASE_URL=https://quartermaster.example.com

# ---------------------------------------------------------------------------
# Optional — kit discovery
# ---------------------------------------------------------------------------

# Path to the kits/ directory where kit subdirectories live.
# The core image ships NO kits — mount your catalog as a volume and point
# QM_KITS_ROOT at it. The Docker image defaults this to /data/kits (the
# container mount point). For a local source checkout it falls back to
# <repo-root>/kits automatically, so you can leave it unset in dev.
# QM_KITS_ROOT=/data/kits

# --- Multi-root layered catalogs (optional) --------------------------------
# Compose several catalogs as ordered layers (base -> overlay). A kit present
# in more than one layer is owned entirely by the highest-priority (last)
# layer, except sections the base marks `frozen = true`, which always survive.
# Each layer gets a URL-safe name, exposed at /api/kits/layers/<name> and
# /dav/<name>/. At least one layer must be writable (readonly = false).
#
# Layers are declared in a TOML file (comments + diff-reviewable). Relative
# layer paths resolve against the file's own directory.
# QM_KIT_LAYERS_FILE=/data/layers.toml
#   # /data/layers.toml
#   [[layer]]
#   name = "company"
#   path = "company-kits"   # relative -> /data/company-kits
#   readonly = true
#   [[layer]]
#   name = "team"
#   path = "team-kits"
#
# Precedence: QM_KIT_LAYERS_FILE (multi-root) overrides QM_KITS_ROOT (single).

# Path to the JSON file recording registered client User-Agents. Non-browser
# clients must register their User-Agent (POST /api/clients) before calling
# the API or MCP endpoint. The Docker image defaults this to
# /data/client_registry.json; mount /data to persist it across restarts.
# QM_CLIENT_REGISTRY_PATH=/data/client_registry.json

# Path to the JSON file storing hashed per-user WebDAV app tokens (the
# credentials used to mount the kit catalog). Docker default:
# /data/app_tokens.json. Mount /data to persist across restarts.
# QM_APP_TOKENS_PATH=/data/app_tokens.json

# Require TLS for the /dav WebDAV endpoint (HTTP Basic credentials must not
# travel over plain HTTP). Keep true in production; set false ONLY for local
# non-TLS testing.
# QM_DAV_REQUIRE_TLS=true

# ---------------------------------------------------------------------------
# DEV ONLY — local auth bypass (NEVER set either of these in production)
# ---------------------------------------------------------------------------
# Lets the app run locally without Keycloak. Both default off; leaving them
# unset is what keeps the bypass inert. See DEVELOPMENT.md.
#
# Mounts the /auth/dev/* token-minting routes (a plain 404 when unset):
# QM_DEV_AUTH_ENABLED=true
#
# HS256 signing secret for dev tokens. When unset, HS256 tokens are rejected
# outright — that is the safe default, so NEVER commit a value or set it in
# production. Use a long random string locally.
# QM_DEV_SHARED_SECRET=change-me-to-a-long-random-local-only-string

# ---------------------------------------------------------------------------
# Optional — fixed Copilot header authentication
# ---------------------------------------------------------------------------

# Enable fixed-header auth for clients that send X-Client-Id and
# X-Client-Secret instead of Authorization: Bearer <token>.
# Header values are validated against the Keycloak token endpoint
# using the client_credentials grant.
# This supplements JWT bearer auth; it does not replace it.
# QM_COPILOT_AUTH_ENABLED=false

# Timeout in seconds for token-endpoint validation requests.
# QM_COPILOT_AUTH_TIMEOUT_SECONDS=3.0

# ---------------------------------------------------------------------------
# Optional — server-side inference for the `resolve_kits` one-shot tool
# ---------------------------------------------------------------------------
# `resolve_kits` turns a free-text task into ranked kits with core content
# inlined, doing the task->trait and section-selection reasoning server-side
# (saving client context). Inference runs LLM -> embeddings -> lexical, falling
# back automatically. The lexical floor always works with zero configuration.

# Local embeddings (deterministic baseline). On by default; requires the
# `embeddings` extra (bundled in the Docker image). Without it the server
# degrades to the lexical floor.
# QM_EMBEDDINGS_ENABLED=true
# QM_EMBEDDINGS_MODEL=BAAI/bge-small-en-v1.5
# Model files + embedding caches live here. The Docker image bakes the model in
# at /app/embeddings, so leave this unset on the image. If you override it, keep
# it OFF the /data volume — a bind mount there masks the baked model.
# QM_EMBEDDINGS_CACHE_DIR=/app/embeddings
# QM_EMBEDDINGS_MIN_SCORE=0.30
# QM_EMBEDDINGS_TOP_K_PER_CATEGORY=4

# Optional LLM layer (off unless a provider + its required fields are set).
# Provider "openai" targets any OpenAI-compatible endpoint (Ollama, vLLM,
# llama.cpp, or cloud) and needs QM_LLM_BASE_URL + QM_LLM_MODEL. Provider
# "anthropic" needs QM_LLM_API_KEY + QM_LLM_MODEL.
# QM_LLM_PROVIDER=openai
# QM_LLM_BASE_URL=http://localhost:11434/v1
# QM_LLM_MODEL=llama3.1
# QM_LLM_API_KEY=
# QM_LLM_TIMEOUT_SECONDS=8.0

# ---------------------------------------------------------------------------
# Optional — maintainer notification (gap-request issue backend)
# ---------------------------------------------------------------------------
# The gap-request MCP tools (check_existing_gap_issue and
# request_clarification_or_addition) are the ONLY part of the server that
# reaches out to an external issue tracker. They are registered — and exposed
# to coding agents — ONLY when a backend is fully configured (GitHub or
# GitLab, below). Leave both unset for a fully self-hosted / air-gapped
# install with no external calls; the tools then do not appear in the MCP and
# the instructions omit them.

# Which backend materializes gap/extension requests: "github", "gitlab", or
# "none" (explicitly disable). Unset defaults to "github" when the GITHUB_*
# settings below are configured (back-compat).
# QM_ISSUE_BACKEND=github

# --- GitHub backend ---------------------------------------------------------
# GitHub repository owner/name where request_clarification_or_addition will
# create issues, and a token with permission to create issues there.
# QM_GITHUB_OWNER=<your-github-owner>
# QM_GITHUB_REPO=<your-github-repo>
# QM_GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# Optional default assignee GitHub username applied to created issues.
# QM_GITHUB_DEFAULT_ASSIGNEE=octocat

# --- GitLab backend (set QM_ISSUE_BACKEND=gitlab to select it) -------------
# Base URL of the GitLab instance (default https://gitlab.com; override for
# self-hosted GitLab), the target project id or URL-encoded path, and a
# token with permission to create issues in that project.
# QM_GITLAB_BASE_URL=https://gitlab.com
# QM_GITLAB_PROJECT_ID=<your-gitlab-project-id-or-path>
# QM_GITLAB_TOKEN=glpat-xxxxxxxxxxxxxxxxxxxx

# Optional default assignee GitLab user id applied to created issues.
# QM_GITLAB_DEFAULT_ASSIGNEE_ID=12345

# ---------------------------------------------------------------------------
# Optional — catalog-recall gap detection
# ---------------------------------------------------------------------------
# When trait inference finds nothing at all for a task, resolve_kits confirms
# that against the whole catalog (not just the inferred vocabulary) before
# surfacing a `gap` in the response — so a task the catalog actually covers,
# just phrased differently, is never mistaken for a missing kit.

# Set false to disable the catalog-recall check entirely (gap is always null).
# QM_GAP_DETECTION_ENABLED=true

# Minimum cosine similarity (embedding recall path) for a trait
# pseudo-document to count as a real catalog match.
# QM_GAP_RECALL_MIN_SCORE=0.30

# Minimum word-overlap count (lexical recall path, used when no embedder is
# available) for a trait pseudo-document to count as a real catalog match.
# QM_GAP_LEXICAL_MIN_OVERLAP=1

# ---------------------------------------------------------------------------
# Optional — per-user memory (personalized ranking nudge)
# ---------------------------------------------------------------------------
# resolve_kits derives a small, capped profile (top domains/kits/languages/
# frameworks) from each authenticated caller's own resolve history, and uses
# it only as a BOUNDED tie-breaker in kit ranking — never a filter, so a
# caller can never be nudged away from content outside their usual pattern.
# View/reset via the get_my_memory/reset_my_memory MCP tools or
# GET/DELETE /api/me/memory.

# Set false to disable memory derivation and personalization entirely.
# QM_USER_MEMORY_ENABLED=true

# Path to the per-subject memory TOML file. A rebuildable derived cache (safe
# to delete), not a source of truth. Docker default: /data/user-memory.toml.
# QM_USER_MEMORY_STORE_PATH=/data/user-memory.toml

# How long (seconds) a cached profile is reused before resolve_kits lazily
# rebuilds it from metrics history.
# QM_USER_MEMORY_TTL_SECONDS=3600

# Exponential-decay half-life (days) for weighting a caller's resolve
# history — recent resolves count more than old ones.
# QM_USER_MEMORY_HALF_LIFE_DAYS=30.0

# Max entries kept per category in a derived profile (keeps it small).
# QM_USER_MEMORY_TOP_DOMAINS=5
# QM_USER_MEMORY_TOP_KITS=5
# QM_USER_MEMORY_TOP_LANGUAGES=3
# QM_USER_MEMORY_TOP_FRAMEWORKS=3

# ---------------------------------------------------------------------------
# Optional — kit version pinning
# ---------------------------------------------------------------------------
# Repos record which major of each kit they follow in a repo-side
# .quartermaster.toml (the server is stateless about pins). See
# QUARTERMASTER_TOML.md. These toggles cover what the server *can* own.

# Record per-kit version-adoption telemetry (feeds the per-kit adoption chart on
# the kit page). Default true.
# QM_VERSION_TELEMETRY_ENABLED=true

# When true (default), an unpinned kit that has shipped a breaking change is
# served at its earliest major with an upgrade advisory. Set false to revert to
# latest-wins for unpinned multi-version kits.
# QM_CONSERVATIVE_DEFAULT_ENABLED=true

# Optional per-kit version policy (min_version / deprecated majors), surfaced in
# the advisory for the agent to enforce. TOML, e.g.:
#   [kits.module-auth-oidc]
#   min_version = "v2"
#   deprecated = ["v1"]
# QM_VERSION_POLICY_FILE=/data/version-policy.toml

# ---------------------------------------------------------------------------
# Optional — logging
# ---------------------------------------------------------------------------
# Logging is configured at startup from the environment, so you can redirect
# logs (disk, logstash, syslog, custom HTTP endpoints) WITHOUT rebuilding the
# image — mount a config file and point QM_LOG_CONFIG at it.

# Level for the default colored console output. Used only when QM_LOG_CONFIG is
# unset. Defaults to INFO.
# QM_LOG_LEVEL=INFO

# Path to a TOML file holding a standard logging.config.dictConfig schema
# (version = 1, formatters, handlers, loggers, root). When set it takes full
# control of logging. Set disable_existing_loggers = false so the uvicorn/app
# loggers survive. A JSON-lines formatter is bundled at
# app.logging_config.JsonLinesFormatter for one-JSON-object-per-line on disk.
# See DEVELOPMENT.md for a complete example.
# QM_LOG_CONFIG=/data/logging.toml
