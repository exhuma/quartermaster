# Python virtual environment — never committed.
.venv/

# Local environment overrides — contains real secrets.
.env

# Byte-compiled cache.
__pycache__/
*.pyc

# Local mutable data (dev-only default for the client registry).
var/

# Build artifacts from the editable/wheel install (uv builds the project now
# that it has a build-system; these are generated, never committed).
build/
*.egg-info/
