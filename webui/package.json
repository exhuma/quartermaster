{
  "name": "quartermaster-webui",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "type-check": "vue-tsc --noEmit",
    "format": "prettier --write \"src/**/*.{ts,vue}\" \"tests/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.{ts,vue}\" \"tests/**/*.ts\"",
    "check:no-dev-auth": "if grep -rqE 'auth/dev|VITE_DEV_AUTH' dist; then echo 'FAIL: dev-auth code leaked into the production build' && exit 1; else echo 'ok: no dev-auth code in dist'; fi"
  },
  "dependencies": {
    "oidc-client-ts": "^3.1.0",
    "vue": "^3.5.0",
    "vue-router": "^4.4.0",
    "vuetify": "^4.1.0"
  },
  "devDependencies": {
    "@mdi/font": "^7.4.0",
    "@vitejs/plugin-vue": "^5.1.0",
    "@vue/test-utils": "^2.4.0",
    "jsdom": "^25.0.0",
    "prettier": "^3.8.5",
    "typescript": "^5.6.0",
    "vite": "^6.0.0",
    "vite-plugin-vuetify": "^2.0.0",
    "vitest": "^2.1.0",
    "vue-tsc": "^2.1.0"
  }
}
