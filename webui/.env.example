# Local-dev (build-time) configuration for `npm run dev`.
# Copy to .env and fill in. In production these are NOT used — the server
# serves /config.js (window.__APP_CONFIG__) rendered from its own env, which
# takes precedence (see src/config.ts and server/app/webui.py).

# Keycloak realm issuer URL (the OIDC authority).
VITE_OIDC_AUTHORITY=https://auth.example.com/realms/master

# Public PKCE client id registered in that realm for this SPA.
VITE_OIDC_CLIENT_ID=quartermaster-webui

# Optional overrides (sensible defaults derive from window.location):
# VITE_OIDC_REDIRECT_URI=http://localhost:5173/auth/callback
# VITE_OIDC_POST_LOGOUT_URI=http://localhost:5173/
# VITE_OIDC_SCOPE=openid profile email

# Optional: API base. Empty/default = same-origin (the dev server proxies
# /api and /kits to http://localhost:8000 — see vite.config.ts).
# VITE_API_BASE_URL=

# Dev-only auth bypass (module-dev-auth-bypass). Set to "true" to skip the
# Keycloak login locally — the app fetches a self-minted dev token from the
# server's /auth/dev endpoint instead. Requires the SERVER to also run with
# DEV_AUTH_ENABLED=true and DEV_SHARED_SECRET set. This flag has effect ONLY
# under `npm run dev`; it folds to `false` in any production build and the
# dev-login code is stripped out. When set, VITE_OIDC_* are not needed.
# VITE_DEV_AUTH=true
